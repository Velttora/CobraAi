# Frontend Next.js — copiar a apps/web/.env.local

# Clerk [REQUERIDO]
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# API Gateway [REQUERIDO]
NEXT_PUBLIC_API_URL=http://localhost:3000

# Import CSV multipart (proxy directo al microservicio, evita límite del gateway)
SERVICE_PORTFOLIOS_URL=http://localhost:3011

# Página pública /pay/:token (BFF → service-payments)
PAYMENTS_SERVICE_URL=http://localhost:3004

# Feature flags [OPCIONAL]
# Muestra el botón para crear nuevas reglas de automatización (oculto por defecto)
NEXT_PUBLIC_ENABLE_WORKFLOW_RULE_CREATION=false
# Habilita el canal SMS. Apagado: todo mensaje SMS se trata/visualiza como WhatsApp
NEXT_PUBLIC_ENABLE_SMS=false
