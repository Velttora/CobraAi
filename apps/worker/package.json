{
  "name": "@renova/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@renova/db": "workspace:*",
    "@renova/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "pg-boss": "^12.18.2",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  }
}
