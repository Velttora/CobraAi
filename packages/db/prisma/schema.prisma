generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  agent
  seller
}

enum InvoiceStatus {
  due_soon
  overdue
  paid
  in_collection
}

enum MessageChannel {
  whatsapp
  voice
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageStatus {
  queued
  sent
  delivered
  read
  failed
  completed
}

model Organization {
  id                    String   @id @default(cuid())
  clerkOrgId            String   @unique
  name                  String
  plan                  String?
  country               String?
  whatsappPhoneNumberId String?
  stripeAccountId       String?
  erpConfig             Json?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  users         User[]
  sellers       Seller[]
  clients       Client[]
  invoices      Invoice[]
  importBatches ImportBatch[]
  conversations  Conversation[]
  campaigns      Campaign[]

  @@index([isActive])
}

model User {
  id             String    @id @default(cuid())
  clerkUserId    String    @unique
  organizationId String
  email          String
  role           UserRole
  sellerId       String?
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  seller       Seller?      @relation(fields: [sellerId], references: [id])

  @@index([organizationId])
  @@unique([organizationId, email])
}

model Seller {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  commissionRate Decimal? @db.Decimal(5, 2)
  recoveryRate   Decimal? @db.Decimal(5, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  users        User[]
  clients      Client[]

  @@index([organizationId])
}

model Client {
  id             String   @id @default(cuid())
  organizationId String
  sellerId       String?
  documentId     String?
  name           String
  phone          String?
  email          String?
  riskScore      Decimal? @db.Decimal(5, 2)
  externalId     String?
  sourceSystem   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  seller       Seller?      @relation(fields: [sellerId], references: [id])
  invoices     Invoice[]
  conversations Conversation[]
  events       CollectionEvent[]

  @@index([organizationId])
  @@index([sellerId])
  @@index([organizationId, phone])
  @@index([organizationId, documentId])
  @@index([organizationId, externalId])
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  clientId       String
  number         String?
  externalId     String?
  sourceSystem   String?
  amount         Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2)
  currency       String        @default("COP")
  issueDate      DateTime?
  dueDate        DateTime
  daysPastDue    Int           @default(0)
  status         InvoiceStatus @default(due_soon)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  client           Client            @relation(fields: [clientId], references: [id])
  paymentLinks     PaymentLink[]
  collectionEvents CollectionEvent[]

  @@index([organizationId])
  @@index([clientId])
  @@index([organizationId, number])
  @@index([status, dueDate])
}

model ImportBatch {
  id             String   @id @default(cuid())
  organizationId String
  storageKey     String
  status         String
  totalRows      Int      @default(0)
  successRows    Int      @default(0)
  errorRows      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  errors       ImportRowError[]

  @@index([organizationId])
}

model ImportRowError {
  id            String @id @default(cuid())
  importBatchId String
  rowNumber     Int
  reason        String
  rawData       Json

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id])

  @@index([importBatchId])
}

model Conversation {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String
  channel        MessageChannel
  status         String   @default("open")
  aiEnabled      Boolean  @default(false)
  lastMessageAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id])
  messages     Message[]
  voiceCalls   VoiceCall[]
  paymentPromises PaymentPromise[]

  @@index([organizationId])
  @@index([clientId])
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  direction      MessageDirection
  author         String?
  status         MessageStatus    @default(queued)
  providerMessageId String?       @unique
  body           String?
  intent         String?
  intentConfidence Decimal?       @db.Decimal(5, 4)
  metadata       Json?
  sentAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
}

model VoiceCall {
  id             String        @id @default(cuid())
  conversationId String
  providerSid    String?       @unique
  status         MessageStatus @default(queued)
  transcript     String?
  outcome        String?
  metadata       Json?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
}

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  channel        MessageChannel
  status         String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model PaymentPromise {
  id             String   @id @default(cuid())
  conversationId String
  invoiceIds     String[]
  amount         Decimal  @db.Decimal(12, 2)
  promiseDate    DateTime
  status         String
  createdBy      String?
  reminderSent   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([status, promiseDate])
}

model PaymentLink {
  id           String    @id @default(cuid())
  invoiceId    String
  stripeLinkId String?   @unique
  url          String
  amount       Decimal   @db.Decimal(12, 2)
  currency     String    @default("COP")
  status       String
  paidAt       DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([status])
}

model CollectionEvent {
  id         String   @id @default(cuid())
  clientId   String
  invoiceId  String?
  eventType  String
  actor      String?
  payload    Json?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  client  Client   @relation(fields: [clientId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([clientId])
  @@index([invoiceId])
  @@index([eventType])
}

model ErpSyncLog {
  id             String    @id @default(cuid())
  sourceSystem   String
  syncType       String
  entitiesSynced Int       @default(0)
  conflicts      Json?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  status         String
  errorDetails   Json?

  @@index([sourceSystem, syncType])
  @@index([status])
}
