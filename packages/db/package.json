{
  "name": "@cobrai/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./nestjs": {
      "types": "./dist/prisma.service.d.ts",
      "default": "./dist/prisma.service.js"
    }
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:seed:align": "tsx src/seed-align.ts",
    "db:backfill-consents": "tsx src/backfill-consents.ts",
    "db:backfill-escalations": "tsx src/backfill-escalations.ts",
    "db:backfill-payment-thank-you": "tsx src/backfill-payment-thank-you.ts",
    "db:clear": "tsx src/clear-database.ts",
    "db:studio": "prisma studio",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "build": "prisma generate && tsc -p tsconfig.json"
  },
  "prisma": {
    "seed": "tsx src/seed-cli.ts"
  },
  "dependencies": {
    "@cobrai/utils": "workspace:*",
    "@cobrai/workflow-packages": "workspace:*",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.22",
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0"
  }
}
