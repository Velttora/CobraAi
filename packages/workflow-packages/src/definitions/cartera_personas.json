{
  "id": "cartera_personas",
  "name": "Cartera personas",
  "description": "Estrategia de cobranza para consumo masivo con contacto frecuente y escalamiento por aging.",
  "profile": "Créditos personales, microcrédito y carteras retail con muchos deudores de ticket medio-bajo.",
  "rules": [
    {
      "name": "Bienvenida — WhatsApp",
      "trigger": "debt_created",
      "condition": { "status": "new" },
      "action": "send_notification",
      "channel": "whatsapp",
      "delay_hours": 0,
      "priority": 10
    },
    {
      "name": "Score medio-bajo — WhatsApp",
      "trigger": "score_updated",
      "condition": { "ai_score": { "lt": 60 }, "whatsapp_opt_in": true },
      "action": "send_notification",
      "channel": "whatsapp",
      "delay_hours": 1,
      "priority": 20
    },
    {
      "name": "Score bajo — WhatsApp",
      "trigger": "score_updated",
      "condition": { "ai_score": { "lt": 40 } },
      "action": "send_notification",
      "channel": "whatsapp",
      "delay_hours": 2,
      "priority": 25
    },
    {
      "name": "Pre-vencimiento -7d — WhatsApp",
      "trigger": "schedule",
      "condition": { "days_to_due": { "gte": 1, "lte": 7 }, "whatsapp_opt_in": true },
      "action": "send_notification",
      "channel": "whatsapp",
      "delay_hours": 0,
      "priority": 28
    },
    {
      "name": "Aging 0-30 — WhatsApp",
      "trigger": "schedule",
      "condition": { "aging_days": { "gte": 0, "lte": 30 }, "whatsapp_opt_in": true },
      "action": "send_notification",
      "channel": "whatsapp",
      "delay_hours": 0,
      "priority": 30
    },
    {
      "name": "Aging 31-60 — WhatsApp",
      "trigger": "schedule",
      "condition": { "aging_days": { "gte": 31, "lte": 60 }, "whatsapp_opt_in": true },
      "action": "send_notification",
      "channel": "whatsapp",
      "delay_hours": 0,
      "priority": 28
    },
    {
      "name": "Aging 61-90 — llamada IA",
      "trigger": "schedule",
      "condition": { "aging_days": { "gte": 61, "lte": 90 } },
      "action": "send_notification",
      "channel": "voice",
      "delay_hours": 0,
      "priority": 20
    },
    {
      "name": "Aging 180+ — escalamiento legal",
      "trigger": "schedule",
      "condition": { "aging_days": { "gte": 181 } },
      "action": "escalate_human",
      "channel": "voice",
      "delay_hours": 0,
      "priority": 5
    },
    {
      "name": "Promesa rota — WhatsApp + tarea",
      "trigger": "promise_broken",
      "condition": {},
      "action": "create_task",
      "channel": "whatsapp",
      "delay_hours": 0,
      "priority": 5
    },
    {
      "name": "Pago confirmado — agradecimiento WhatsApp",
      "trigger": "payment_confirmed",
      "condition": { "amount_outstanding": 0 },
      "action": "send_notification",
      "channel": "whatsapp",
      "delay_hours": 0,
      "priority": 10
    }
  ]
}
